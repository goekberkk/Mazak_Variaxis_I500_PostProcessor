  {
       G_return[$mom_sys_return_code]
       Y[0]
  }

  BLOCK_TEMPLATE return_home_X 
  {
       G_return[$mom_sys_return_code]
       X[0]
  }

  BLOCK_TEMPLATE return_home_4th5th 
  {
       G_return[$mom_sys_return_code]
       fourth_axis[0]
       fifth_axis[0]
  }

  BLOCK_TEMPLATE fixture_offset 
  {
       G[$mom_fixture_offset_value + 53]
  }

  BLOCK_TEMPLATE tool_change_auto 
  {
       T[$mom_tool_number]
       T_next[$mom_next_tool_number]
       M[$mom_sys_tool_change_code]
       Text[$mom_tool_comment]\opt
  }

